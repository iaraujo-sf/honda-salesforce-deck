        end

        subgraph WB["<b>CRM WRITEBACK (Seletivo)</b>"]
            W1["<b>→ Core recebe só:</b><br/>• Oportunidades<br/>• Cases<br/>• Accounts core"]
            W2["<i>(Não carrega tudo!)</i>"]
            W1 ~~~ W2
        end

        subgraph DL["<b>DATA LAKE (Databricks)</b>"]
            DL1["• Histórico full<br/>• Analytics<br/>• BI (Qlik)<br/>• Dados corp.<br/>• ML/AI"]
        end
    end

    %% ========================================
    %% CORE LAYER
    %% ========================================
    subgraph CORE["<b>SALESFORCE CORE (Transacional)</b>"]
        C1["<b>Operação leve:</b><br/>• Oportunidades<br/>• Cases<br/>• Accounts mínimo"]
        C2["<i>(Leve, sem VUC)</i>"]
        C1 ~~~ C2
    end

    %% ========================================
    %% MAIN FLOWS
    %% ========================================
    DEALERS --> ESB
    VENDAS --> ESB
    HSF --> ESB

    ESB ==> DC

    DC ==> ACT
    DC ==> WB
    DC ==> DL

    WB --> CORE

