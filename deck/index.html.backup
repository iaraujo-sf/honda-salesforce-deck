  <!-- SLIDE 7: PRÓXIMOS PASSOS -->
  <div class="slide">
    <div class="s7-bg"></div>
    <!-- Sparkles -->
    <svg class="sparkle silver" style="left: 6%; top: 18%; width: 46px; height: 46px; animation-delay: 0.6s;" viewBox="0 0 24 24">
      <path d="M12 0l2.4 9.6L24 12l-9.6 2.4L12 24l-2.4-9.6L0 12l9.6-2.4L12 0z" fill="#FFFFFF" opacity="0.7"/>
    </svg>
    <svg class="sparkle silver" style="right: 8%; top: 20%; width: 40px; height: 40px; animation-delay: 1.7s;" viewBox="0 0 24 24">
      <path d="M12 0l2.4 9.6L24 12l-9.6 2.4L12 24l-2.4-9.6L0 12l9.6-2.4L12 0z" fill="#FFFFFF" opacity="0.6"/>
    </svg>
    <svg class="sparkle silver" style="left: 9%; bottom: 24%; width: 36px; height: 36px; animation-delay: 2.4s;" viewBox="0 0 24 24">
      <path d="M12 0l2.4 9.6L24 12l-9.6 2.4L12 24l-2.4-9.6L0 12l9.6-2.4L12 0z" fill="#FFFFFF" opacity="0.5"/>
    </svg>
    <div class="s7-content">
      <h2 class="s7-title">Princípios de Design</h2>
      <div class="s7-steps">
        <div class="s7-step">
          <div class="glass"></div>
          <h3 class="s7-step-title">1. Ativar, não carregar</h3>
          <p class="s7-step-desc">Core leve e transacional. Ativação direta do Data Cloud para canais (Email, SMS, WhatsApp, Push, Agent Force) — sem passar pelo Core.</p>
        </div>
        <div class="s7-step">
          <div class="glass"></div>
          <h3 class="s7-step-title">2. Substituição gradual</h3>
          <p class="s7-step-desc">DW descomissionado por tipo de dado, em ondas sucessivas, com execução paralela durante transição. Fallback preservado.</p>
        </div>
        <div class="s7-step">
          <div class="glass"></div>
          <h3 class="s7-step-title">3. Data Lake para histórico</h3>
          <p class="s7-step-desc">Dados corporativos não-CRM, analytics pesado e histórico completo vão para Databricks (já em produção) — não para Data Cloud.</p>
        </div>
        <div class="s7-step">
          <div class="glass"></div>
          <h3 class="s7-step-title">4. VUC → Unified Profile</h3>
          <p class="s7-step-desc">Identity Resolution não duplicada. Unified Profile do Data Cloud substitui VUC — não convive com ela. Lógica única.</p>
        </div>
        <div class="s7-step">
          <div class="glass"></div>
          <h3 class="s7-step-title">5. Segmentação sem SQL</h3>
          <p class="s7-step-desc">Se uma jornada migrada ainda depende de query SQL pesada, a migração não cumpriu objetivo — apenas trocou plataforma do timeout.</p>
        </div>
        <div class="s7-step">
          <div class="glass"></div>
          <h3 class="s7-step-title">6. Writeback seletivo</h3>
          <p class="s7-step-desc">Core recebe apenas o que precisa para operações transacionais. Evita recriar problema do limite MC Connect no novo cenário.</p>
        </div>
      </div>
      <div class="s7-cta">
        Enterprise Architecture POV • Substituição DW por Data Cloud • Sem Recriar Anti-Padrão
      </div>
    </div>
  </div>

</div>

<script>
  // CURSOR
  const cursor = document.querySelector('.cursor');
  let mouseX = 0, mouseY = 0;
  let cursorX = 0, cursorY = 0;

  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  });

  function animateCursor() {
    const dx = mouseX - cursorX;
    const dy = mouseY - cursorY;
    cursorX += dx * 0.15;
    cursorY += dy * 0.15;
    cursor.style.left = cursorX + 'px';
    cursor.style.top = cursorY + 'px';
    requestAnimationFrame(animateCursor);
  }
  animateCursor();

  document.querySelectorAll('a, button, .nav-btn, .dot, .s2-card, .s3-problem, .s5-phase, .s6-benefit, .s7-step').forEach(el => {
    el.addEventListener('mouseenter', () => cursor.classList.add('big'));
    el.addEventListener('mouseleave', () => cursor.classList.remove('big'));
  });

  // NAVEGAÇÃO
  let current = 0;
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.dot');
  const total = slides.length;
  const progress = document.getElementById('progress');
  const counter = document.getElementById('counter');

  function goto(n) {
    if (n < 0 || n >= total) return;

    slides[current].classList.remove('active');
    current = n;
    slides[current].classList.add('active');

    dots.forEach((d, i) => d.classList.toggle('active', i === current));
    progress.style.width = ((current + 1) / total * 100) + '%';
    counter.textContent = String(current + 1).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');
  }

  document.getElementById('nav-next').addEventListener('click', () => goto(current + 1));
  document.getElementById('nav-prev').addEventListener('click', () => goto(current - 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goto(i)));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === ' ') goto(current + 1);
    if (e.key === 'ArrowLeft') goto(current - 1);
  });

  // INIT
  progress.style.width = (1 / total * 100) + '%';
</script>

</body>
</html>
